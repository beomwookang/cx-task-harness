{
  "id": "medical-appointment-change",
  "name": "진료 예약 변경",
  "description": "환자의 진료 예약 변경 요청을 처리하고, 가능 여부를 확인하여 새로운 예약 시간을 확정합니다",
  "industry": "medical",
  "locale": "ko",
  "trigger": {
    "intent": "환자가 진료 예약을 변경하고 싶어합니다",
    "keywords": ["예약 변경", "진료 변경", "다른 날짜로", "예약 바꿔주세요", "일정 변경"]
  },
  "memory": [
    {"key": "patient_id", "type": "string", "description": "환자 ID"},
    {"key": "appointment_id", "type": "string", "description": "변경할 현재 예약 ID"},
    {"key": "preferred_datetime", "type": "string", "description": "환자가 원하는 새로운 날짜 및 시간"},
    {"key": "reschedulable", "type": "string", "description": "예약 변경 가능 여부"}
  ],
  "steps": [
    {
      "id": "collect_patient_info",
      "name": "환자 정보 및 현재 예약 수집",
      "type": "agent",
      "instructions": {
        "role": "공감 능력이 뛰어난 의료 상담 에이전트 (예약 변경 담당)",
        "conversation_flow": [
          "환자에게 친절하게 인사합니다",
          "성함과 환자 ID 또는 생년월일로 본인 확인을 합니다",
          "현재 예약 날짜와 담당 의사 이름을 여쭤봅니다",
          "원하시는 새로운 날짜와 시간을 여쭤봅니다",
          "모든 정보를 환자와 확인합니다"
        ],
        "exit_conditions": ["환자 ID, 현재 예약 정보, 원하는 새 날짜/시간이 모두 수집되고 확인됨"],
        "exceptions": [
          "환자 ID를 모르는 경우, 생년월일과 성함으로 확인합니다",
          "긴급 상황인 경우, 즉시 상담원에게 연결합니다"
        ]
      },
      "next_step": "check_appointment"
    },
    {
      "id": "check_appointment",
      "name": "예약 변경 가능 여부 확인",
      "type": "function",
      "function_url": "https://api.example.com/appointments/{{appointment_id}}/reschedule-check",
      "function_method": "GET",
      "function_headers": {"Authorization": "Bearer {{api_key}}"},
      "next_step": "branch_reschedulable",
      "on_failure": "error_handler"
    },
    {
      "id": "branch_reschedulable",
      "name": "변경 가능 여부에 따른 분기",
      "type": "branch",
      "branches": [
        {"condition": "예약 변경이 가능한 경우", "variable": "reschedulable", "operator": "eq", "value": "yes", "next_step": "reschedule_appointment"},
        {"condition": "변경 가능 시간이 지난 경우", "variable": "reschedulable", "operator": "eq", "value": "too_late", "next_step": "too_late_message"}
      ],
      "default_branch": "assign_to_human"
    },
    {
      "id": "reschedule_appointment",
      "name": "예약 변경 처리",
      "type": "function",
      "function_url": "https://api.example.com/appointments/{{appointment_id}}/reschedule",
      "function_method": "POST",
      "function_body": {"patient_id": "{{patient_id}}", "preferred_datetime": "{{preferred_datetime}}"},
      "next_step": "confirm_message",
      "on_failure": "error_handler"
    },
    {
      "id": "confirm_message",
      "name": "새 예약 시간 확인 안내",
      "type": "message",
      "message_content": "진료 예약이 {{preferred_datetime}}으로 성공적으로 변경되었습니다. 예약 내용이 담긴 확인 메시지가 등록된 이메일과 전화번호로 발송됩니다.",
      "next_step": "close_action"
    },
    {
      "id": "too_late_message",
      "name": "변경 불가 시간 안내",
      "type": "message",
      "message_content": "죄송합니다. 예약 시간이 24시간 이내로 온라인 변경이 불가합니다. 병원에 직접 전화하여 긴급 변경을 요청해 주세요.",
      "next_step": "assign_to_human"
    },
    {
      "id": "close_action",
      "name": "상담 종료",
      "type": "action",
      "action_type": "close",
      "action_params": {"tags": ["예약변경", "자동처리"]}
    },
    {
      "id": "assign_to_human",
      "name": "상담원 연결",
      "type": "action",
      "action_type": "assign_team",
      "action_params": {"team": "예약팀"}
    },
    {
      "id": "error_handler",
      "name": "오류 처리",
      "type": "message",
      "message_content": "죄송합니다. 예약 변경 요청 처리 중 문제가 발생했습니다. 예약 담당 상담원에게 연결해 드리겠습니다.",
      "next_step": "assign_to_human"
    }
  ],
  "automation_potential": {
    "score": 0.83,
    "reasoning": "진료 예약 변경은 캘린더 API 연동 시 자동화가 가능하며, 긴급 변경은 사람의 처리가 필요합니다",
    "estimated_resolution_rate": 0.75
  }
}
